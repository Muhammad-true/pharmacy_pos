# =============================================================================
# Шаблон настроек окружения (скопируйте в .env и заполните своими значениями)
# В Git коммитить только этот файл. Файл .env — не коммитить (пароли и секреты).
# =============================================================================

# Тип БД (для проекта используется mysql)
DATABASE_TYPE=mysql

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=pharmacy_db
MYSQL_SSL_ENABLED=false

# Приложение
APP_VERSION=1.0.0
# URL JSON с информацией об обновлениях (оставьте пустым, если не используется)
UPDATE_URL=
